#!/usr/bin/env bash
set -euo pipefail

host="${PLATFORM_HOST:-platform}"
remote_artifact_dir="${PLATFORM_HOMEPAGE_ARTIFACT_DIR:-/srv/platform/artifacts/homepage}"
remote_deploy_script="${PLATFORM_HOMEPAGE_DEPLOY_SCRIPT:-/srv/platform/infra/scripts/deploy-homepage}"
tmp_dir="$(mktemp -d)"

cleanup() {
    rm -rf "$tmp_dir"
}

trap cleanup EXIT

bun run build:oracle

cp -R dist/standalone/. "$tmp_dir/"
mkdir -p "$tmp_dir/dist"
cp -R dist/static "$tmp_dir/dist/static"
cp -R public "$tmp_dir/public"

COPYFILE_DISABLE=1 tar -C "$tmp_dir" -czf - . | ssh "$host" "
    set -euo pipefail
    mkdir -p \"$(dirname "$remote_artifact_dir")\"
    next_dir=\"\$(mktemp -d \"${remote_artifact_dir}.XXXXXX\")\"
    tar -xzf - -C \"\$next_dir\"
    rm -rf \"${remote_artifact_dir}.previous\"
    if [ -d \"$remote_artifact_dir\" ]; then
        mv \"$remote_artifact_dir\" \"${remote_artifact_dir}.previous\"
    fi
    mv \"\$next_dir\" \"$remote_artifact_dir\"
"

ssh "$host" "$remote_deploy_script"
